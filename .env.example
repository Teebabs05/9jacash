# =====================================================
# 9JACASH ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your real values.
# This file is loaded by config/config.php at runtime.
# =====================================================

APP_NAME="9JACASH"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Africa/Lagos
APP_CURRENCY=NGN
APP_CURRENCY_SYMBOL=₦
APP_KEY=

# ---------------------------------------------------
# Database
# ---------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=9jacash
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ---------------------------------------------------
# Mail (SMTP - PHPMailer)
# ---------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@9jacash.com
MAIL_FROM_NAME="9JACASH"

# ---------------------------------------------------
# PayVessel Payment Gateway
# ---------------------------------------------------
PAYVESSEL_PUBLIC_KEY=
PAYVESSEL_SECRET_KEY=
PAYVESSEL_BASE_URL=https://api.payvessel.com
PAYVESSEL_WEBHOOK_SECRET=

# ---------------------------------------------------
# Security
# ---------------------------------------------------
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
