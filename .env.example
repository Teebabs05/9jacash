# =====================================================
# SURECASH MINING ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your real values.
# This file is loaded by config/config.php at runtime.
# =====================================================

APP_NAME="SURECASH MINING"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.com
APP_TIMEZONE=Africa/Lagos
APP_CURRENCY=NGN
APP_CURRENCY_SYMBOL=₦
APP_KEY=

# ---------------------------------------------------
# Database
# ---------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=surecash_mining
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ---------------------------------------------------
# Mail (SMTP - PHPMailer)
# ---------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=no-reply@surecashmining.com
MAIL_FROM_NAME="SURECASH MINING"

# ---------------------------------------------------
# PayVessel Payment Gateway
# API docs: https://payvessel.gitbook.io/payvessel/
# ---------------------------------------------------
PAYVESSEL_PUBLIC_KEY=
PAYVESSEL_SECRET_KEY=
PAYVESSEL_BUSINESS_ID=
PAYVESSEL_BASE_URL=https://api.payvessel.com
# Comma-separated bank codes PayVessel should issue the reserved account against.
PAYVESSEL_BANK_CODES=120001

# ---------------------------------------------------
# Security
# ---------------------------------------------------
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Only set this to true if this site is genuinely behind a reverse proxy
# or CDN (e.g. Cloudflare) that overwrites client-supplied X-Forwarded-For/
# CF-Connecting-IP headers with the real client IP. Leaving this false
# (the safe default for plain shared hosting) means rate limiting and IP
# logging use the raw TCP connection IP, which a client cannot spoof.
TRUST_PROXY_HEADERS=false
