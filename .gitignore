# Environment
.env

# Generated at install time by install/index.php - each deployment
# creates its own; committing one would make a fresh install wrongly
# think it's already set up.
install/installed.lock

# Logs
logs/*.log
logs/*.txt

# User uploaded content (keep folder structure via .gitkeep)
uploads/kyc/*
uploads/receipts/*
uploads/tasks/*
uploads/avatars/*
uploads/branding/*
!uploads/kyc/.gitkeep
!uploads/receipts/.gitkeep
!uploads/tasks/.gitkeep
!uploads/avatars/.gitkeep
!uploads/branding/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
.claude/

# Composer (kept intentionally for shared hosting deploys without SSH/composer access)
# vendor/ is committed on purpose - do not ignore.
