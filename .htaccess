RewriteEngine On

# ---------------------------------------------------------------
# Force HTTPS (uncomment on production once SSL is installed)
# ---------------------------------------------------------------
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---------------------------------------------------------------
# Block access to sensitive files
# ---------------------------------------------------------------
<FilesMatch "\.(env|sql|log|md|lock|json|gitignore)$">
    Require all denied
</FilesMatch>

<Files "config.php">
    <RequireAll>
        Require all granted
    </RequireAll>
</Files>

# Deny direct access to config.php via PHP handler is unnecessary; but block .env explicitly
<Files ".env">
    Require all denied
</Files>
<Files ".env.example">
    Require all denied
</Files>

# ---------------------------------------------------------------
# Disable directory listing
# ---------------------------------------------------------------
Options -Indexes

# ---------------------------------------------------------------
# Protect sensitive directories from direct web access
# ---------------------------------------------------------------
RewriteRule ^(config|includes|database|logs|vendor|docs)/ - [F,L]

# Lock the installer out entirely once the site has been installed -
# nothing under /install/ (DB credentials wizard, schema loader) should
# stay reachable on a live production site.
RewriteCond %{DOCUMENT_ROOT}/install/installed.lock -f
RewriteRule ^install/ - [F,L]

# ---------------------------------------------------------------
# Block common vulnerability-scanner / exploit-probe requests at the
# web-server layer, before PHP even boots (belt-and-suspenders on top
# of the application-level firewall in includes/firewall.php).
# ---------------------------------------------------------------
RewriteRule ^wp-(login\.php|admin|content|includes|json) - [F,L]
RewriteRule ^xmlrpc\.php$ - [F,L]
RewriteRule (^|/)\.(git|svn|hg)(/|$) - [F,L]
RewriteRule ^(phpmyadmin|pma|myadmin|adminer(\.php)?)(/|$) - [F,L]
RewriteRule ^cgi-bin/ - [F,L]
RewriteRule (^|/)(shell|c99|r57|wso|b374k|webshell)\.php$ - [F,L]

# ---------------------------------------------------------------
# Hide server/technology fingerprint (domain & hosting recon defense)
# ---------------------------------------------------------------
ServerSignature Off

# ServerTokens (trims the Apache version string, e.g. "Apache" instead of
# "Apache/2.4.41 (Ubuntu) PHP/8.2.1") can only be set in the main server
# config (httpd.conf / apache2.conf), never in .htaccess. On shared cPanel
# hosting, ask your host to set "ServerTokens Prod", or add it yourself if
# you have root/WHM access. Likewise, hiding the PHP version from the
# X-Powered-By header at the source (belt-and-suspenders with the Header
# unset below) requires `expose_php = Off` in php.ini.
<IfModule mod_headers.c>
    Header unset X-Powered-By
    Header always unset X-Powered-By
</IfModule>

# ---------------------------------------------------------------
# Security headers
# ---------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ---------------------------------------------------------------
# Compression
# ---------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json
</IfModule>

# ---------------------------------------------------------------
# Browser caching for static assets
# ---------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType font/woff2 "access plus 1 month"
</IfModule>

# These only apply under mod_php. Most modern shared hosting (including
# cPanel) runs PHP via php-fpm/suPHP instead, where an unguarded php_flag/
# php_value in .htaccess causes Apache to fail the ENTIRE request with a
# 500 error rather than just being ignored - confirmed by actually testing
# this file against a real Apache install without mod_php loaded. If your
# host uses php-fpm, set these via your control panel's PHP settings
# (e.g. cPanel's "MultiPHP INI Editor") or a local php.ini instead.
<IfModule mod_php.c>
    php_flag display_errors off
    php_value upload_max_filesize 10M
    php_value post_max_size 12M
</IfModule>
